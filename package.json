{
  "name": "minimo-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:web": "bun run apps/web/build.ts && bunx @tailwindcss/cli -i apps/web/src/styles/globals.css -o apps/web/dist/styles.css --minify",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun apps/api/src/migrate.ts",
    "dev:api": "bun --watch apps/api/src/index.ts",
    "watch:css": "bunx @tailwindcss/cli -i apps/web/src/styles/globals.css -o apps/web/dist/styles.css --watch"
  },
  "dependencies": {
    "@biomejs/biome": "^2.5.2",
    "@elysiajs/static": "^1.4.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "bun": "^1.3.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "lucide-react": "^1.23.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/bun": "latest",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.0"
  },
  "version": "0.1.0"
}